		// morning-brief：兼容旧接口 + 独立 section 接口
		mb := v1.Group("/morning-brief")
		{
			mb.GET("", morningBriefHandler.Get)
			sections := mb.Group("/sections")
			{
				sections.GET("/market",     morningBriefHandler.GetMarket)
				sections.GET("/position",   morningBriefHandler.GetPosition)
				sections.GET("/buy-plans",  morningBriefHandler.GetBuyPlans)
				sections.GET("/reports",    morningBriefHandler.GetReports)
				sections.GET("/valuation",  morningBriefHandler.GetValuation)
				sections.GET("/news",       morningBriefHandler.GetNews)
				sections.GET("/ai-comment", morningBriefHandler.GetAIComment)
			}
		}

		admin := v1.Group("/admin")
		{
			scan := admin.Group("/scan")
			{
				scan.POST("/run", scanHandler.RunScan)
				scan.GET("/today", scanHandler.ListTodayScans)
				scan.GET("/history", scanHandler.ListScansByDate)
			}
		}
	}

	if cfg.AppEnv == "development" {
		for _, ri := range r.Routes() {
			log.Sugar().Debugf("%-8s %s", ri.Method, ri.Path)
		}
	}

	return r, discoverySvc, auditSvc, marketSentinelSvc, stockReportSvc,
		valuationSvc, morningBriefSvc, equitySvc, screenerTemplateSvc
}
