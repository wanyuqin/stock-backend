# ── 应用 ──────────────────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8888

# ── PostgreSQL（与 docker-compose.yml 保持一致）────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=stock_password_123
DB_NAME=stock_system
DB_SSLMODE=disable

# ── Redis ──────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── CORS（多个源用英文逗号分隔）────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI 分析（硅基流动 SiliconFlow）────────────────────────────────
# 注册地址：https://cloud.siliconflow.cn
# API Key 在控制台「API 密钥」页面生成
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型 ID（留空则使用默认值 Qwen/Qwen2.5-72B-Instruct）
# 免费可用模型参考：
#   Qwen/Qwen2.5-72B-Instruct      （推荐，中文最强，免费）
#   Qwen/Qwen2.5-7B-Instruct       （更快，轻量）
#   deepseek-ai/DeepSeek-V3        （推理能力强）
#   THUDM/glm-4-9b-chat            （轻量免费）
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
